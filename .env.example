# API 服务监听端口；Docker Compose 默认映射 HOST_PORT -> PORT。
PORT=8080
HOST_PORT=18080
# 外部访问本服务的根地址；飞书 OAuth callback 会使用它。
PUBLIC_BASE_URL=http://localhost:18080

# 本地数据目录。Docker Compose 中容器内固定使用 /app/data 和 /app/work。
DATA_DIR=./data
WORK_DIR=./work
DB_PATH=./data/tasks.sqlite

# 是否开启鉴权。生产建议 AUTH_ENABLED=true。
AUTH_ENABLED=false
# 是否校验数据 API Key；AUTH_ENABLED=false 时此项不会生效。
AUTH_API_KEY_ENABLED=true
# 兼容静态 API Key，逗号分隔；更推荐在 /admin 创建可吊销 key。
API_KEYS=

# 飞书 OAuth 单管理员后台配置；AUTH_ENABLED=true 时用于 /admin 登录。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_AUTH_BASE=https://accounts.feishu.cn
FEISHU_API_BASE=https://open.feishu.cn
SESSION_TTL_HOURS=24
HTTP_TIMEOUT_SECONDS=30

# Android Package Service 配置。APS_BASE_URL 必填，不要把真实地址提交到仓库。
APS_BASE_URL=
APS_API_KEY=
APS_DOWNLOAD_TIMEOUT_SECONDS=21600
APS_JOB_POLL_SECONDS=10

# 并发控制：顶层任务、下载、dump、pair compare 分别限流。
TASK_CONCURRENCY=2
DOWNLOAD_CONCURRENCY=4
DUMP_CONCURRENCY=2
COMPARE_CONCURRENCY=2

# 本地 macOS 可留空让代码自动找 lib/product/osx；Docker Compose 固定使用 /app/lib/product/.../linux。
IL2CPP_DUMPER_PATH=
IL2CPP_DUMPER_TIMEOUT_SECONDS=3600
DLL_ANALYZER_PATH=
DLL_ANALYZER_TIMEOUT_SECONDS=300

# 报告存储。local 写入 DATA_DIR/reports；gcs/s3 会在查询任务时返回 signed URL。
REPORT_STORAGE_BACKEND=local
REPORT_SIGNED_URL_TTL_SECONDS=3600
REPORT_STORAGE_PREFIX=unity-compare-reports

# REPORT_STORAGE_BACKEND=gcs 时配置。
REPORT_GCS_BUCKET=
# 可填 service account JSON 内容或 JSON 文件路径。
REPORT_GCS_CREDENTIALS_JSON=

# REPORT_STORAGE_BACKEND=s3 时配置；兼容 S3-compatible endpoint。
REPORT_S3_BUCKET=
REPORT_S3_REGION=
REPORT_S3_ENDPOINT_URL=
REPORT_S3_ACCESS_KEY_ID=
REPORT_S3_SECRET_ACCESS_KEY=

# AI 分析配置。未配置 OPENAI_API_KEY 时 HTML 会显示未配置提示。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# 工作目录清理。失败任务默认也清理，排障时可临时 KEEP_FAILED_WORK_DIR=true。
KEEP_FAILED_WORK_DIR=false
WORK_DIR_TTL_HOURS=24
WORKER_POLL_SECONDS=2

# Web 容器运行参数，仅 Dockerfile/gunicorn 使用。
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT_SECONDS=21600
